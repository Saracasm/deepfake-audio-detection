data/raw/
data/processed/
checkpoints/
*.pt
*.pth
*.ckpt
*.bin

# Logs
logs/
wandb/
*.log

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.pytest_cache/
